func fibonacci(n: i32) -> i32 {
    var a = 0;
    var b = 1;
    var i = 0;
    while i < n {
        let next = a + b;
        a = b;
        b = next;
        i = i + 1;
    };
    return a;
}

func sum_evens(n: i32) -> i32 {
    var i = 0;
    var s = 0;
    while i < n {
        i = i + 1;
        if (i / 2) * 2 != i {
            continue;
        };
        s = s + i;
    };
    return s;
}

func main() -> i32 {
    return fibonacci(10) + sum_evens(10);
}
